PORT=4300

# Local web development only. Production mobile/web builds should use a deployed HTTPS API.
EXPO_PUBLIC_API_URL=http://localhost:4300

# Optional. Without this, analysis returns unavailable with no skip segments.
OPENAI_API_KEY=

# whisper-1 supports verbose_json segment timestamps used by this MVP.
OPENAI_TRANSCRIBE_MODEL=whisper-1

# Transcription endpoint uploads are capped; keep this under the provider file limit.
MAX_TRANSCRIPTION_AUDIO_MB=24

# Server-side fetch safety limits.
MAX_FEED_XML_MB=3
MAX_EPISODES_PER_FEED=150
FETCH_TIMEOUT_MS=15000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=80
ANALYZE_RATE_LIMIT_WINDOW_MS=3600000
ANALYZE_RATE_LIMIT_MAX_REQUESTS=6
ANALYZE_MAX_CONCURRENT=2
OPML_MAX_CHARS=200000
OPML_MAX_NODES=2000
OPML_MAX_DEPTH=24
OPML_VALIDATE_CONCURRENCY=8

# Comma-separated allowed browser origins for deployed APIs.
# Empty keeps local development without OpenAI permissive; production and OpenAI-enabled APIs require at least one origin.
CORS_ORIGINS=

# Shared token for the expensive /api/analyze endpoint.
# ANALYZE_API_TOKEN is required whenever OPENAI_API_KEY is set.
ANALYZE_API_TOKEN=
EXPO_PUBLIC_ANALYZE_API_TOKEN=

# Unsafe local development escape hatch only; cannot be used in production.
ALLOW_ANY_CORS_ORIGIN=false
ALLOW_UNAUTHENTICATED_ANALYZE=false
